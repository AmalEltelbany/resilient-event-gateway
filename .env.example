# App
PORT=3000
NODE_ENV=development

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=secret
MONGO_DB=resilient-event-gateway
MONGO_URI=mongodb://root:secret@localhost:27017/resilient-event-gateway?authSource=admin

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispassword

# Security
WEBHOOK_SECRET=change-me-to-a-strong-random-secret

# Queue
EVENT_QUEUE_NAME=events
QUEUE_JOB_ATTEMPTS=3
QUEUE_BACKOFF_DELAY_MS=3000
