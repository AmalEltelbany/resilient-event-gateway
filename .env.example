# App
PORT=3000
NODE_ENV=development

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=secret
MONGO_DB=resilient-event-gateway
MONGO_URI=mongodb://root:secret@localhost:27017/resilient-event-gateway?authSource=admin

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispassword

# Security
WEBHOOK_SECRET=change-me-to-a-strong-random-secret
API_KEY=change-me-to-a-strong-api-key

# Queue
EVENT_QUEUE_NAME=events
QUEUE_JOB_ATTEMPTS=3
QUEUE_BACKOFF_DELAY_MS=3000

# Routing (set to 0 in production, 0.2 for demo, 0.5 for stress testing)
ROUTING_FAILURE_RATE=0.2

# Rate limiting (global default; per-route overrides are defined in the controller)
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=200

# Outbox reconciliation (scans for stale PENDING events and re-enqueues them)
OUTBOX_INTERVAL_MS=300000
OUTBOX_STALE_THRESHOLD_MS=300000
