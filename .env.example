# App
PORT=3000
NODE_ENV=development

# MongoDB
# When using docker-compose, MONGO_URI is overridden by the compose file — no changes needed here.
# For local dev outside Docker, point this at your local mongod (must run with --replSet rs0).
MONGO_URI=mongodb://localhost:27017/resilient-event-gateway?replicaSet=rs0&directConnection=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispassword

# Security — change both before exposing to any network
WEBHOOK_SECRET=change-me-to-a-strong-random-secret
API_KEY=internal-api-key-change-me

# Queue
QUEUE_JOB_ATTEMPTS=3
QUEUE_BACKOFF_DELAY_MS=3000

# Routing: probability of simulated downstream failure (0 = always succeed)
ROUTING_FAILURE_RATE=0

# Rate limiting
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=200

# Outbox publisher
OUTBOX_INTERVAL_MS=5000
OUTBOX_STALE_THRESHOLD_MS=60000

# Replay attack window (ms). Set to 0 to disable.
WEBHOOK_REPLAY_WINDOW_MS=300000
